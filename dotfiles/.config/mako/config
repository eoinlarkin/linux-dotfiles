# Mako Configuration
# Inspired by following configuration:
# https://github.com/lokesh-krishna/dotfiles/blob/main/nord-v3/config/mako/config

# configuration:
sort=-time
layer=overlay
ignore-timeout=0
default-timeout=10000
font=monospace 10
group-by=summary

# colors:
background-color=#3b4252
text-color=#eceff4

# height and width:
width=350
height=110
margin=0,20,20
padding=10

# borders:
border-size=2
border-color=#4c566a
border-radius=5

# icons:
icons=1
max-icon-size=64

[urgency=low]
# border-color=#cccccc

[urgency=normal]
# border-color=#d08770

[urgency=high]
border-color=#bf616a
default-timeout=0

[grouped]
format=<b>%s</b>\n%b
